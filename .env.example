# Public — readable from client. Both are emitted by `supabase status -o env`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# AI providers — Anthropic primary, OpenAI fallback (wired in v1.1 via callAI()).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Feature flag — when truthy, surfaces AI preview UI (v1.1 only).
NEXT_PUBLIC_AI_PREVIEW=
